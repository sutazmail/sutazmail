# docker-mailserver configuration (template — no secrets belong in this file).
# Full reference: https://docker-mailserver.github.io/docker-mailserver/latest/config/environment/
# Secrets (DMS_API_KEY) are injected from .env via docker-compose, not stored here.

# --- Core ---
LOG_LEVEL=info
# Postfix accepts mail for these domains via the account list; no extra setting needed.

# --- TLS ---
# letsencrypt = use certs from /etc/letsencrypt (mount them in docker-compose.yml);
# self-signed is used if unset — fine for a first boot, NOT for production mail.
# See https://docker-mailserver.github.io/docker-mailserver/latest/config/security/ssl/
SSL_TYPE=

# --- Services ---
ENABLE_RSPAMD=1
ENABLE_OPENDKIM=0
ENABLE_OPENDMARC=0
ENABLE_POLICYD_SPF=0
ENABLE_CLAMAV=0
ENABLE_FAIL2BAN=1
ENABLE_MANAGESIEVE=1

# --- Storage quotas (Dovecot) ---
ENABLE_QUOTAS=1

# --- Spam handling (rspamd) ---
SPAM_SUBJECT=[SPAM]
MOVE_SPAM_TO_JUNK=1

# --- Misc ---
# 1 = containers on the docker network may relay without auth. Keep 'none' unless
# other containers must send mail through this server.
PERMIT_DOCKER=none
