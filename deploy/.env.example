# SutazMail full-stack deployment — environment template.
# ./deploy.sh generates a filled-in .env for you (recommended), or copy this file
# to .env and fill it in by hand. NEVER commit the filled-in .env.
# NOTE: docker-compose interpolates `$` in .env — bcrypt hashes must escape `$` as `$$`.

# --- Identity ---
# Primary mail domain (first domain served; more can be added in the UI later).
MAIL_DOMAIN=example.com
# The mail server's FQDN — MX target, TLS certificate name, HELO name.
MAIL_HOSTNAME=mail.example.com

# --- SutazMail app ---
# Host port the app binds on 127.0.0.1 (put your HTTPS reverse proxy in front).
APP_HOST_PORT=8095
# Optional: webmail base URL for the one-click "Open webmail" buttons (Roundcube etc.).
WEBMAIL_URL=

# --- Database ---
POSTGRES_USER=sutazmail
POSTGRES_PASSWORD=
POSTGRES_DB=sutazmail
# App connection string (host = the db service name).
DATABASE_URL=postgresql://sutazmail:CHANGE_ME@sutazmail-db:5432/sutazmail

# --- docker-mailserver REST bridge ---
MAILSERVER_API_URL=http://mailserver:8888
# Shared key between the app and the bridge (generate: openssl rand -hex 32).
DMS_API_KEY=

# --- ManageSieve / Dovecot (end-user auth + sieve management) ---
MAILSERVER_SIEVE_HOST=mailserver
MAILSERVER_SIEVE_PORT=4190
# TLS SNI for STARTTLS — must match the mailserver certificate name.
MAILSERVER_TLS_SERVERNAME=mail.example.com
# 1 = verify the cert chain strictly; 0 = accept (internal docker network / self-signed).
MAILSERVER_TLS_REJECT_UNAUTHORIZED=0
# App-owned Dovecot master account (deploy.sh creates it:
#   docker compose exec mailserver setup dovecot-master add sutazmail '<password>').
MASTER_SIEVE_USER=sutazmail
MASTER_SIEVE_PASSWORD=

# --- Platform superadmin (seeded on start) ---
SUPERADMIN_EMAIL=
# bcrypt hash of the superadmin password ($ escaped as $$). Generate with:
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 12))" 'YOUR_PASSWORD'
SUPERADMIN_PASSWORD_HASH=

# --- Sessions ---
# HMAC secret for signing the session cookie (generate: openssl rand -hex 32).
SESSION_SECRET=

NODE_ENV=production
