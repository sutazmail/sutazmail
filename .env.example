# SutazMail v2 environment. Copy to `.env` in the stack dir on the NAS and fill in secrets.
# NOTE: docker-compose interpolates `$` in .env — bcrypt hashes must escape `$` as `$$`.

# --- Database (sutazmail-db service; internal network only) ---
POSTGRES_USER=sutazmail
POSTGRES_PASSWORD=
POSTGRES_DB=sutazmail
# App connection string (host = the db service name on sutazmail-internal).
DATABASE_URL=postgresql://sutazmail:CHANGE_ME@sutazmail-db:5432/sutazmail

# --- docker-mailserver REST bridge (resolved by name on tottynotti-network) ---
MAILSERVER_API_URL=http://mailserver:8888
# The mail server's REST API key (raw string, sent as the Authorization header).
DMS_API_KEY=

# --- ManageSieve / Dovecot (end-user auth + sieve management) ---
MAILSERVER_SIEVE_HOST=mailserver
MAILSERVER_SIEVE_PORT=4190
# TLS SNI for STARTTLS (the mailserver cert is issued for its mail hostname).
MAILSERVER_TLS_SERVERNAME=mail.tottynotti.com
# 1 = verify the cert chain strictly; 0 = accept (internal docker network).
MAILSERVER_TLS_REJECT_UNAUTHORIZED=0
# App-owned Dovecot master account (create once:
#   docker exec mailserver setup dovecot-master add sutazmail '<password>').
MASTER_SIEVE_USER=sutazmail
MASTER_SIEVE_PASSWORD=

# --- Platform superadmin (seeded on start) ---
SUPERADMIN_EMAIL=
# bcrypt hash of the superadmin password ($ escaped as $$). Generate with:
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 12))" 'YOUR_PASSWORD'
SUPERADMIN_PASSWORD_HASH=

# --- Sessions ---
# HMAC secret for signing the session cookie. Generate with: openssl rand -hex 32
SESSION_SECRET=

NODE_ENV=production
